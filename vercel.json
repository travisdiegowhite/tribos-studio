{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "crons": [
    {
      "path": "/api/garmin-token-maintenance",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/garmin-webhook-process",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/proactive-insights-process",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/coros-webhook-process",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/coros-token-maintenance",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/database-cleanup",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/fitness-snapshots?action=compute-weekly",
      "schedule": "0 3 * * 1"
    },
    {
      "path": "/api/recompute-user-tau?action=recompute-all",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/workout-preview-cron",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/welcome-email",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/activation-nudge",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/coach-correction-trigger",
      "schedule": "0 12 * * *"
    }
  ],
  "functions": {
    "api/admin.js": {
      "maxDuration": 60
    },
    "api/email-tool.js": {
      "maxDuration": 60
    },
    "api/garmin-webhook-process.js": {
      "maxDuration": 60
    },
    "api/coros-webhook-process.js": {
      "maxDuration": 60
    },
    "api/database-cleanup.js": {
      "maxDuration": 60
    },
    "api/fitness-snapshots.js": {
      "maxDuration": 60
    },
    "api/workout-preview-cron.js": {
      "maxDuration": 60
    },
    "api/coach-correction-trigger.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/((?!api/|assets/).*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
