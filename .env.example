# ============================================================================
# TRIBOS.STUDIO ENVIRONMENT VARIABLES
# ============================================================================
# Copy this file to .env.local for development.
# Add these to Vercel environment variables for production.
# ============================================================================

# ⚠️ CRITICAL SECURITY RULES:
# 1. NEVER use service_role key for VITE_SUPABASE_ANON_KEY (must be "anon" role)
# 2. NEVER add VITE_ prefix to secrets (service keys, client secrets, API keys)
# 3. Server-only keys are only accessed via process.env in /api/ routes
# 4. Client-side keys (VITE_*) are visible in browser — only use public tokens

# ============================================================================
# FRONTEND (VITE_ prefix — exposed to browser at build time)
# ============================================================================

# ----------------------------------------------------------------------------
# Supabase (client-side)
# ----------------------------------------------------------------------------
# In Supabase Dashboard > Settings > API:
# - Use "anon" public key (NOT service_role!)
# - JWT should have "role": "anon" when decoded
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ----------------------------------------------------------------------------
# App metadata / API base
# ----------------------------------------------------------------------------
VITE_APP_VERSION=0.1.0
# Base URL used when constructing OAuth redirect URIs (server-side reads this
# via process.env.VITE_APP_URL). Falls back to https://www.tribos.studio.
VITE_APP_URL=http://localhost:3000
# API base for fetch() calls — leave empty to use same-origin (recommended).
# Only set if frontend is served from a different origin than /api routes.
VITE_API_URL=
VITE_API_BASE_URL=

# ----------------------------------------------------------------------------
# Maps & routing (client-side)
# ----------------------------------------------------------------------------
# Mapbox public token (pk.*) — used for map rendering and geocoding
VITE_MAPBOX_TOKEN=your-mapbox-public-token-here

# Stadia Maps (bike-optimized routing via Valhalla)
# Free tier: 10,000 routes/month — https://stadiamaps.com/
VITE_STADIA_API_KEY=your-stadia-api-key-here
VITE_USE_STADIA_MAPS=true

# ----------------------------------------------------------------------------
# Monitoring & analytics (optional)
# ----------------------------------------------------------------------------
# Sentry error tracking — create a project at https://sentry.io/
VITE_SENTRY_DSN=

# PostHog product analytics — create a project at https://posthog.com/
VITE_PUBLIC_POSTHOG_KEY=
VITE_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ----------------------------------------------------------------------------
# OAuth (frontend — Connect buttons + redirect URIs)
# ----------------------------------------------------------------------------
# Strava
VITE_STRAVA_CLIENT_ID=your-strava-client-id
VITE_STRAVA_REDIRECT_URI=http://localhost:3000/oauth/strava/callback

# Garmin Connect (OAuth 1.0a)
VITE_GARMIN_CONSUMER_KEY=your-garmin-consumer-key

# Wahoo Fitness (OAuth 2.0)
# CRITICAL: VITE_WAHOO_REDIRECT_URI and WAHOO_REDIRECT_URI must be identical
VITE_WAHOO_CLIENT_ID=your-wahoo-client-id
VITE_WAHOO_REDIRECT_URI=http://localhost:3000/wahoo/callback

# COROS (OAuth 2.0)
VITE_COROS_CLIENT_ID=your-coros-client-id
VITE_COROS_REDIRECT_URI=http://localhost:3000/oauth/coros/callback

# Google Calendar (OAuth 2.0)
VITE_GOOGLE_CLIENT_ID=your-google-client-id
VITE_GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:3000/oauth/google/callback

# ----------------------------------------------------------------------------
# Push notifications (Web Push / VAPID — public key)
# ----------------------------------------------------------------------------
# Generate with: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=

# ----------------------------------------------------------------------------
# Feature flags
# ----------------------------------------------------------------------------
# Env-level kill switch for Route Builder 2.0 BETA. Access requires BOTH this
# flag AND the per-user user_profiles.route_builder_v2_enabled column set to
# true (Stabilize S1). When this is "false", NO ONE can reach v2 — direct URL
# access to /route-builder-2 redirects to v1, and the BUILDER 2.0 nav link is
# hidden, even for users whose column is true. This is defense in depth.
VITE_ROUTE_BUILDER_V2_ENABLED=false

# ============================================================================
# BACKEND (server-side only — DO NOT add VITE_ prefix)
# ============================================================================

# ----------------------------------------------------------------------------
# Supabase (server-side)
# ----------------------------------------------------------------------------
# Use "service_role" secret key for SUPABASE_SERVICE_KEY (server-only!)
# JWT should have "role": "service_role" when decoded.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ----------------------------------------------------------------------------
# AI & external data services
# ----------------------------------------------------------------------------
# Anthropic Claude (for AI route generation + coaching)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Mapbox server-side token (geocoding + directions in /api routes).
# Can be same as VITE_MAPBOX_TOKEN if the token has sufficient scopes.
MAPBOX_ACCESS_TOKEN=your-mapbox-server-token

# OpenWeatherMap (weather-aware route suggestions)
# Free key at https://openweathermap.org/api
OPENWEATHER_API_KEY=your-openweather-api-key

# GraphHopper routing API (legacy fallback — Stadia/Valhalla is primary)
# Naming is REACT_APP_* for historical reasons; still read by process.env.
REACT_APP_GRAPHHOPPER_API_KEY=

# ----------------------------------------------------------------------------
# Email (Resend)
# ----------------------------------------------------------------------------
RESEND_API_KEY=your-resend-api-key
RESEND_WEBHOOK_SECRET=your-resend-webhook-secret

# ----------------------------------------------------------------------------
# OAuth (server-side secrets)
# ----------------------------------------------------------------------------
# Strava
STRAVA_CLIENT_ID=your-strava-client-id
STRAVA_CLIENT_SECRET=your-strava-client-secret
# Strava webhook — generate any random string, register at:
# https://developers.strava.com/docs/webhooks/
STRAVA_WEBHOOK_VERIFY_TOKEN=your-random-verify-token

# Garmin Connect (OAuth 1.0a)
# Register at https://developer.garmin.com/gc-developer-program/
GARMIN_CONSUMER_KEY=your-garmin-consumer-key
GARMIN_CONSUMER_SECRET=your-garmin-consumer-secret
GARMIN_CALLBACK_URL=https://yourdomain.com/oauth/garmin/callback
# HMAC secret for the Cloudflare Garmin webhook proxy
GARMIN_WEBHOOK_SECRET=your-garmin-webhook-secret

# Wahoo Fitness
# Register at https://developers.wahooligan.com/
WAHOO_CLIENT_ID=your-wahoo-client-id
WAHOO_CLIENT_SECRET=your-wahoo-client-secret
WAHOO_REDIRECT_URI=http://localhost:3000/wahoo/callback
# Wahoo webhook — generate any random string, register webhook URL as:
# https://yourdomain.com/api/wahoo-webhook?token=YOUR_TOKEN
WAHOO_WEBHOOK_TOKEN=your-random-webhook-token

# COROS (OAuth 2.0)
# Apply at COROS Open Platform; test domain: opentest.coros.com
COROS_CLIENT_ID=your-coros-client-id
COROS_CLIENT_SECRET=your-coros-client-secret
COROS_CALLBACK_URL=https://yourdomain.com/oauth/coros/callback
# Optional: use test environment during development
COROS_API_BASE=https://open.coros.com

# Google Calendar (OAuth 2.0)
# https://console.cloud.google.com/ → enable Calendar API → create OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ----------------------------------------------------------------------------
# Push notifications (server-side VAPID keys)
# ----------------------------------------------------------------------------
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_MAILTO=mailto:you@example.com

# ----------------------------------------------------------------------------
# Operations
# ----------------------------------------------------------------------------
# Admin gate — email that gets admin-only access in /api routes
ADMIN_EMAIL=travis@tribos.studio

# CORS allow-list for /api routes (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:3000,https://www.tribos.studio

# Shared secret for Vercel cron endpoints — must match `x-cron-secret` header
CRON_SECRET=your-random-cron-secret

# Production base URL used by OAuth callbacks when not running locally
PRODUCTION_URL=https://www.tribos.studio

# Site URL (legacy var name — kept for one or two callers)
NEXT_PUBLIC_SITE_URL=https://www.tribos.studio

# ----------------------------------------------------------------------------
# Node runtime
# ----------------------------------------------------------------------------
NODE_ENV=development
